    {"id": "kitchen_alcove",  "label": "KITCHEN ALCOVE",  "kind": "search",    "pos_xy": [300,  250], "search_pile": "kitchen_alcove"},
    {"id": "grill",           "label": "GRILL",           "kind": "named",     "pos_xy": [200,  340]},
