  "drift_attractors": {
    "notes": "Visitors that linger on the board without a connection drift toward these spaces during the Drift phase. Items the room produces (Gravity-card events like THE BBS HUMS, A SECOND COUNTER WIPE that spawn items) appear here. Engine implementation pending — flagged here for the next pass.",
    "primary": "hostess_stand",
    "secondary": "bar",
    "tertiary": "booth_4"
  },
  "space_effects": {
    "hostess_stand": {
      "on_end_action_phase": [{"kind": "peek_next_visitor_arrival", "note": "you watch the door for whoever's next"}]
    },
    "bar": {
      "on_end_action_phase": [{"kind": "gain_inertia", "amount": 1, "note": "loitering by a closed bar — the room registers the gesture"}]
    },
    "dish_station": {
      "on_end_action_phase": [{"kind": "lose_inertia", "amount": 1, "note": "the dishwasher's meditative effect"}]
    },
    "bathroom": {
      "on_end_action_phase": [{"kind": "gain_time_next_planning", "amount": 1, "note": "a moment of privacy"}]
    },
    "pay_phone": {
      "on_end_action_phase": [{"kind": "peek_next_gravity", "note": "the call gives you a beat"}]
    },
    "cig_machine": {
      "on_end_action_phase": [{"kind": "draw_extra_item", "from_pile": "register", "amount": 1, "note": "the machine spits a wrapper", "facedown": true}]
    },
    "bar_stools": {
      "on_end_action_phase": [{"kind": "if_visitor_at_counter", "visitor": "frasier",
        "then": [{"kind": "auto_connect_visitor", "visitor": "frasier", "note": "alternate Frasier connect — sit on the next stool"}]}]
    },
    "grill": {
      "on_end_action_phase": [{"kind": "if_visitor_at_kitchen_alcove", "visitor": "dawn_cook",
        "then": [{"kind": "auto_connect_visitor", "visitor": "dawn_cook", "note": "alternate Dawn Cook connect — at the grill beside him"}]}]
    },
    "order_window": {
      "on_end_action_phase": [{"kind": "ring_bell_tone", "note": "the cook strikes the order bell"}]
    },
    "booth_1": {
      "on_end_action_phase": [{"kind": "peek_register_pile", "note": "newspaper headline shows tomorrow's"}]
    },
    "booth_4": {
      "on_end_action_phase": [{"kind": "lose_inertia", "amount": 1, "note": "the private booth where Frasier used to draft"}]
    },
    "back_door": {
      "on_end_action_phase": [{"kind": "log", "text": "Cold air through the back. Smell of asphalt + river."}]
    },
    "jukebox": {
      "on_end_action_phase": [{"kind": "log", "text": "The selected side spins one more time before clicking off."}]
    }
  },
  "events": [
    {
      "id": "dawn_not_quite_dawn",
