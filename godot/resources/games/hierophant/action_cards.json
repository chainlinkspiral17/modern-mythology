{
  "scope": "hierophant",
  "notes": "Sysop's keeper-of-the-room loop. BOOT / WELCOME / TRANSMIT / RECEIVE as starters. Signal is the positive doom-clock; Doctrine is the spendable currency.",
  "cards": [
    {
      "id": "boot",
      "title": "BOOT",
      "time_cost": 1,
      "starter": true,
      "stock": 99,
      "flavor": "Wake the terminal. Bring the modem up. Doctrine rises.",
      "requires": [ { "kind": "at_pos", "pos": "crt_terminal" } ],
      "effects": [
        { "kind": "gain_doctrine", "amount": 1 }
      ]
    },
    {
      "id": "welcome",
      "title": "WELCOME",
      "time_cost": 1,
      "starter": true,
      "stock": 99,
      "flavor": "Acknowledge a caller. Their step advances; the room remembers they came.",
      "requires": [ { "kind": "visitor_at_my_pos_progress_at_least", "n": 1 } ],
      "effects": [
        { "kind": "advance_visitor_step", "step": "listen" }
      ]
    },
    {
      "id": "transmit",
      "title": "TRANSMIT",
      "time_cost": 2,
      "starter": true,
      "stock": 99,
      "flavor": "Post a thread. The signal rises; the room reads it.",
      "requires": [
        { "kind": "at_pos", "pos": "crt_terminal" },
        { "kind": "has_doctrine_at_least", "n": 1 }
      ],
      "effects": [
        { "kind": "spend_doctrine", "amount": 1 },
        { "kind": "tick_signal", "amount": 1 }
      ]
    },
    {
      "id": "receive",
      "title": "RECEIVE",
      "time_cost": 2,
      "starter": true,
      "stock": 99,
      "flavor": "Read what came in. Bring a visitor through their delivery step.",
      "requires": [
        { "kind": "visitor_at_my_pos_progress_at_least", "n": 2 }
      ],
      "effects": [
        { "kind": "advance_visitor_step", "step": "deliver" }
      ]
    },
    {
      "id": "archive_pull",
      "title": "ARCHIVE PULL",
      "time_cost": 1,
      "starter": false,
      "stock": 3,
      "buy_only_at": "floppy_wall",
      "flavor": "Pull a floppy from the wall. Print the contents.",
      "requires": [ { "kind": "at_pos", "pos": "floppy_wall" } ],
      "effects": [
        { "kind": "gain_doctrine", "amount": 2 }
      ]
    },
    {
      "id": "the_long_signal",
      "title": "THE LONG SIGNAL",
      "time_cost": 0,
      "starter": false,
      "stock": 1,
      "flavor": "Transmit a message that everyone in the room reads. The next visitor in any space arrives on the next turn.",
      "effects": [
        { "kind": "advance_visitor_schedule", "amount": 2 }
      ]
    },
    {
      "id": "kettle",
      "title": "KETTLE",
      "time_cost": 1,
      "starter": false,
      "stock": 2,
      "buy_only_at": "back_kitchen",
      "flavor": "Put the kettle on. The room steadies. Anyone in the couch corner gets a step.",
      "requires": [ { "kind": "at_pos", "pos": "back_kitchen" } ],
      "effects": [
        { "kind": "lose_doubt", "amount": 1 },
        { "kind": "patch_two_spaces", "a": "back_kitchen", "b": "couch_corner", "turns": 2 }
      ]
    },
    {
      "id": "ham_call",
      "title": "HAM CALL",
      "time_cost": 2,
      "starter": false,
      "stock": 1,
      "buy_only_at": "ham_radio",
      "flavor": "Dial up the ham band. The voice from 14.301 answers.",
      "requires": [ { "kind": "at_pos", "pos": "ham_radio" } ],
      "effects": [
        { "kind": "advance_visitor_schedule", "amount": 1 },
        { "kind": "gain_doctrine", "amount": 1 }
      ]
    }
  ]
}
