{
  "scope": "fool",
  "notes": "12 cards drawn one-per-turn during the Shadow phase. Spec: lore/_TAROT_GAUNTLET.md §IV.7.",
  "cards": [
    {
      "id": "the_clock_holds",
      "title": "THE CLOCK HOLDS",
      "flavor": "Three forty-seven AM. Three forty-seven AM. Three forty-seven AM.",
      "effects": [
        {"kind": "set_next_time_reset", "value": 5},
        {"kind": "gain_inertia", "amount": 1}
      ]
    },
    {
      "id": "wipe_the_same_spot",
      "title": "WIPE THE SAME SPOT",
      "flavor": "The routine wanted it.",
      "effects": [
        {"kind": "if_played_this_turn", "card": "wipe_counter",
         "then": [{"kind": "log", "text": "Counter wiped. No penalty."}],
         "else": [{"kind": "gain_inertia", "amount": 1}]}
      ]
    },
    {
      "id": "still_chasing_shadows",
      "title": "STILL CHASING SHADOWS, JOHNNY?",
      "flavor": "Frasier's voice from the kitchen.",
      "effects": [
        {"kind": "advance_visitor_arrival", "visitor": "frasier", "by": 1, "only_if_not_arrived": true},
        {"kind": "gain_inertia", "amount": 1}
      ]
    },
    {
      "id": "the_fluorescent_tick",
      "title": "THE FLUORESCENT TICK",
      "flavor": "Every two seconds, a yellow tick.",
      "effects": [
        {"kind": "this_turn_time_cost_modifier", "min_cost_for_bump": 2, "bump": 1}
      ]
    },
    {
      "id": "the_counter_wants_wiping",
      "title": "THE COUNTER WANTS WIPING",
      "flavor": "It's almost the same spot. It always is.",
      "endgame": true,
      "effects": [
        {"kind": "choose", "options": [
          {"label": "Discard 2 Action cards", "effects": [{"kind": "discard_hand", "amount": 2}]},
          {"label": "+2 Inertia",             "effects": [{"kind": "gain_inertia", "amount": 2}]}
        ]}
      ]
    },
    {
      "id": "the_graffiti_hand",
      "title": "THE GRAFFITI HAND",
      "flavor": "FRANKLY / FOOLISH, in someone's same patient hand.",
      "effects": [
        {"kind": "reveal_lore_token", "token": "graffiti_signature_seen"}
      ]
    },
    {
      "id": "the_bell_rings",
      "title": "THE BELL RINGS (ONE TONE)",
      "flavor": "Brass on coil. One tone. The other waits.",
      "effects": [
        {"kind": "ring_bell_tone"},
        {"kind": "if_both_tones_rung", "then": [
          {"kind": "advance_next_visitor_arrival", "by": 1}
        ]}
      ]
    },
    {
      "id": "the_painted_pose",
      "title": "THE PAINTED POSE",
      "flavor": "Somewhere across town, in a room you've never been to, you are already a painting.",
      "effects": [
        {"kind": "if_visitor_not_connected", "visitor": "stranger",
         "then": [{"kind": "gain_inertia", "amount": 1}]}
      ]
    },
    {
      "id": "the_steamboat_echo",
      "title": "THE STEAMBOAT ECHO",
      "flavor": "Red, reflected. In the diner window. Always.",
      "effects": [
        {"kind": "reveal_lore_token", "token": "steamboat_echo_seen"},
        {"kind": "if_arcana_completed", "arcana": "magician",
         "then": [{"kind": "lose_inertia", "amount": 1}]}
      ]
    },
    {
      "id": "the_fellow_traveler",
      "title": "THE FELLOW TRAVELER",
      "flavor": "Faith's nose finds your ankle.",
      "effects": [
        {"kind": "move_visitor", "visitor": "faith", "to": "player_pos"}
      ]
    },
    {
      "id": "twelve_years",
      "title": "TWELVE YEARS",
      "flavor": "The apron knows the date even when you don't.",
      "endgame": true,
      "effects": [
        {"kind": "gain_inertia", "amount": 2}
      ]
    },
    {
      "id": "nine_locust_seventeen_door",
      "title": "NINE LOCUST SEVENTEEN DOOR",
      "flavor": "The number-sequence whispering from under the formica.",
      "endgame": true,
      "effects": [
        {"kind": "reveal_threshold", "threshold": "precipice_door"},
        {"kind": "set_flag", "key": "counter_haunted", "value": true,
         "note": "every subsequent turn standing on COUNTER adds +1 Inertia"}
      ]
    }
  ]
}
