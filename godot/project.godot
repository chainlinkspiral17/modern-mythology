; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[application]

config/name="Modern Mythology (Copy)"
config/version="0.1.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/run/main_scene="res://scenes/Main.tscn"

[autoload]

Settings="*res://autoload/Settings.gd"
AudioMgr="*res://autoload/AudioMgr.gd"
SceneDataDB="*res://autoload/SceneDataDB.gd"
SaveSystem="*res://autoload/SaveSystem.gd"
SkinDB="*res://autoload/SkinDB.gd"
Inventory="*res://autoload/Inventory.gd"
GauntletState="*res://autoload/GauntletState.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[gdscript]

warnings/treat_warnings_as_errors=false
warnings/inferred_declaration_assigned_to_variant=0
warnings/unsafe_cast=0

