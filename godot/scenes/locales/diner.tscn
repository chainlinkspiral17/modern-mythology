shape = SubResource("Box_WestExt_Floor")

; Outer west wall of the extension (X=-15.25, the new picture-window
; wall — TODO: cut collision opening to match window if we make it
; passable in-game)
[node name="WestExt_WallW" type="StaticBody3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -15.25, 2.5, 0)

[node name="WestExt_WallWShape" type="CollisionShape3D" parent="WestExt_WallW"]
shape = SubResource("Box_WestExt_Wall_EW")

; North wall of the extension
[node name="WestExt_WallN" type="StaticBody3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -12, 2.5, -6.25)

[node name="WestExt_WallNShape" type="CollisionShape3D" parent="WestExt_WallN"]
shape = SubResource("Box_WestExt_Wall_NS")

; South wall of the extension
[node name="WestExt_WallS" type="StaticBody3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -12, 2.5, 6.25)

[node name="WestExt_WallSShape" type="CollisionShape3D" parent="WestExt_WallS"]
shape = SubResource("Box_WestExt_Wall_NS")

; HeroJohn is HIDDEN here — the player IS John in the Fool scenario,
; so showing the figure inside the same diner would be John watching
; himself (breaks first-person POV). The model still LOADS so the
; Background3D SubViewport (used by VN bg) gets the same hierarchy
; if it needs to override visibility later.
[node name="HeroJohn" parent="." instance=ExtResource("9_john")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.95, -1)
visible = false

; Player spawned at the canonical THE LEAP opening vantage:
; AT the counter (Blender X=0, Y=-2.65 → Godot Z=+2.65), facing
; north (Godot -Z, which is the default Camera3D look direction —
; no basis rotation needed at the Player level). The
; DinerGauntletHost re-applies this on _ready() so changing the
; scenario start space later only requires editing the host's map.
[node name="Player" type="CharacterBody3D" parent="." groups=["player"]]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 2.65)
script = ExtResource("2_fpc")

[node name="CollisionShape3D" type="CollisionShape3D" parent="Player"]
shape = SubResource("Caps_Player")
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.85, 0)

[node name="Camera3D" type="Camera3D" parent="Player"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.65, 0)
fov = 65.0
near = 0.05
far = 100.0

; ── Tarot-Gauntlet wiring: THE LEAP (Fool · D'Ambrosio's) ──
; Maps the 24 gauntlet board spaces to 3D positions in this scene,
; positions the Player at the canonical scenario opener on _ready,
; and offers Ctrl+F12 to launch TarotGauntletGame from inside the
; diner (handy for testing without going through Gallery).
[node name="DinerGauntletHost" type="Node3D" parent="."]
script = ExtResource("17_gauntlet")
player_path = NodePath("../Player")
auto_position_on_ready = true

[node name="PostProcess" type="CanvasLayer" parent="."]
layer = 50
script = ExtResource("5_mood")
mood_strata = Array[String](["raw", "substrate_press", "linework_overlay", "linework_multiply", "linework", "blueprint_red", "lithograph", "noir", "ink_blue", "high_contrast_bw", "anime_motion", "motion_blur", "dream_blur", "macro_haze", "studio", "psychedelic_substrate", "lightshow_extreme", "silent_film_24", "silent_film_18", "silent_film_12", "kitchen_practical", "bar_pendant_amber", "dawn_warm", "sodium_streetlamp", "fluorescent_corridor", "gauntlet_intro"])
default_style_pack = "dambrosios_3am"

[node name="NeonQuad" type="ColorRect" parent="PostProcess"]
material = SubResource("Mat_Neon")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2

