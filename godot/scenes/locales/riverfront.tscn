; ── KEY LIGHTS ────────────────────────────────────────────────────
; Three DirectionalLight3Ds working as a cinematographer's three-light
; pattern. KEY = moon (cool, the main shaper). FILL = warm dim bounce
; (simulates ground/asphalt return). BACK = cool cyan rim from the
; far shore (separates boat silhouette from the river/sky).
[node name="Moon_Key" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866, -0.354, 0.354, 0, 0.707, 0.707, -0.5, -0.612, 0.612, 0, 20, 0)
light_color = Color(0.62, 0.72, 0.95, 1)
light_energy = 0.32
shadow_enabled = false

[node name="Fill_Bounce" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866, 0.354, -0.354, 0, 0.707, 0.707, 0.5, -0.612, 0.612, 0, 5, 0)
light_color = Color(0.98, 0.82, 0.62, 1)
light_energy = 0.08
shadow_enabled = false

[node name="Back_Rim" type="DirectionalLight3D" parent="."]
transform = Transform3D(0, -0.5, 0.866, 0, 0.866, 0.5, -1, 0, 0, 0, 25, 0)
light_color = Color(0.58, 0.78, 0.95, 1)
light_energy = 0.22
shadow_enabled = false

; ── PRACTICAL LIGHTS · parking-lot sodium lamps ───────────────────
; Three omnis at the actual sodium-lamp-head positions baked in the
; GLB. Coords are Blender → Godot remapped (sodium head at Blender
; (-30, ±16.2, 5.78) or (-39.2, 0, 5.78) → Godot (X, 5.78, ∓16.2) or
; (-39.2, 5.78, 0)). High-pressure-sodium warm orange ≈ 2100K.
[node name="Sodium_S" type="OmniLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -30, 5.78, 16.2)
light_color = Color(1.0, 0.68, 0.34, 1)
light_energy = 1.6
omni_range = 7.0
shadow_enabled = false

[node name="Sodium_N" type="OmniLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -30, 5.78, -16.2)
light_color = Color(1.0, 0.68, 0.34, 1)
light_energy = 1.6
omni_range = 7.0
shadow_enabled = false

[node name="Sodium_W" type="OmniLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -39.2, 5.78, 0)
light_color = Color(1.0, 0.68, 0.34, 1)
light_energy = 1.6
omni_range = 7.0
shadow_enabled = false

; ── PRACTICAL LIGHTS · dock lanterns ──────────────────────────────
; Two TALL pier-lamps at the dock's N/S corners (matching the
; DockLamp_Pole + DockLamp_Glow mesh pair) and four SHORT bollard
; lanterns spaced along the dock's river-facing edge. Each Light3D
; lines up with its visible lamp-head mesh — kill any one of them
; without the geometry going dark in a weird way.
[node name="DockLamp_S" type="OmniLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7.0, 1.8, 7.4)
light_color = Color(1.0, 0.78, 0.42, 1)
light_energy = 1.1
