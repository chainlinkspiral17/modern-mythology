; ── SIGN SPOT · directed light on the D'Ambrosio's pole sign ──────
; SpotLight3D from above-front so the sign reads bright against the
; dark scene without flooding the parking lot. Sign panel is in the
; SE corner of the lot at Godot (-18.5, 5.7, 16). Spot above and a
; touch outboard, narrow cone aimed at the panel face.
[node name="SignSpot" type="SpotLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.5, 0.866, 0, -0.866, 0.5, -18.5, 9.5, 18.5)
light_color = Color(1.0, 0.92, 0.78, 1)
light_energy = 1.2
spot_range = 5.0
spot_angle = 22.0
spot_attenuation = 1.8
shadow_enabled = false

