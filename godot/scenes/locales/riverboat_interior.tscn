visible = false

; ── RiverboatGauntletHost ────────────────────────────────────────
; Maps the 13 station + 3 threshold spaces from
; resources/games/locations/riverboat_interior.json to 3D positions
; built by build_riverboat_interior.py. Auto-positions player at
; the MAÎTRE D' STAND on scene-open (Empress/Nicola opens there —
; the host's post, friday night).
[node name="RiverboatGauntletHost" type="Node3D" parent="."]
